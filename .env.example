# All keys optional. Adapters auto-skip when their key is empty.
# Marginalia, Wikipedia, and Hacker News do not require keys.

# Brave Search API. Free tier available.
# https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# Mojeek Search API. Paid.
# https://www.mojeek.com/services/search/web-search-api/
MOJEEK_API_KEY=

# Marginalia public key. Request from operator.
# Anonymous "test" key currently returns 500 from upstream; adapter auto-disables.
# https://memex.marginalia.nu/projects/edge/api.gmi
MARGINALIA_API_KEY=

# GitHub personal access token. Optional — without it the GitHub adapter still
# works but with stricter unauthenticated rate limits.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Base URL of a self-hosted or trusted public SearXNG instance (no trailing
# slash). Leave empty to disable the SearXNG adapter.
# e.g. WEBSEARCH_SEARXNG_BASE_URL=https://searx.example.org
WEBSEARCH_SEARXNG_BASE_URL=

# Optional override: defaults to bind on 0.0.0.0 so LAN clients reach it.
PORT=3040
HOST=0.0.0.0

# Active lens file. See lenses/default.json.
WEBSEARCH_LENS=lenses/default.json

# UA string sent to upstreams.
WEBSEARCH_USER_AGENT=websearch/0.1 (+https://github.com/nathanib/websearch)

# Disk-backed result cache. On by default; set WEBSEARCH_CACHE=off to disable.
# Privacy: cache keys are SHA-256 hashes of (query, lens, limit) — the raw
# query text is never written to disk. Cached payloads do echo the query back
# in the result body, so the cache dir should be treated as sensitive even so.
WEBSEARCH_CACHE=on
WEBSEARCH_CACHE_DIR=data/cache
WEBSEARCH_CACHE_TTL_MS=3600000
